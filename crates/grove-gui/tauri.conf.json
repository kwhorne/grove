{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grove",
  "version": "0.1.0",
  "identifier": "com.elyra.grove.gui",
  "build": {
    "frontendDist": "ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Grove",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520,
        "center": true,
        "focus": true,
        "visible": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
